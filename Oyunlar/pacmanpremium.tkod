btnAsagi.renk = "#ffffff";
btnAsagi.stil = "font-size:24px;font-weight:bold;border-radius:8px;";

Dugme btnSol;
btnSol.yazi = "⬅️";
btnSol.x = 310;
btnSol.y = 200;
btnSol.genislik = 50;
btnSol.yukseklik = 50;
btnSol.arkaplan = "#f0a000";
btnSol.renk = "#ffffff";
btnSol.stil = "font-size:24px;font-weight:bold;border-radius:8px;";

Dugme btnSag;
btnSag.yazi = "➡️";
btnSag.x = 420;
btnSag.y = 200;
btnSag.genislik = 50;
btnSag.yukseklik = 50;
btnSag.arkaplan = "#f0a000";
btnSag.renk = "#ffffff";
btnSag.stil = "font-size:24px;font-weight:bold;border-radius:8px;";

Dugme btnBaslat;
btnBaslat.yazi = "▶ BAŞLAT";
btnBaslat.x = 345;
btnBaslat.y = 320;
